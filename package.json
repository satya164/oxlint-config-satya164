{
  "name": "oxlint-config-satya164",
  "version": "0.1.1",
  "description": "Personal Oxlint Config of @satya164",
  "type": "module",
  "license": "MIT",
  "files": ["dist/configs"],
  "exports": {
    "./recommended": {
      "types": "./dist/configs/recommended.d.ts",
      "default": "./dist/configs/recommended.js"
    },
    "./react": {
      "types": "./dist/configs/react.d.ts",
      "default": "./dist/configs/react.js"
    },
    "./typechecked": {
      "types": "./dist/configs/typechecked.d.ts",
      "default": "./dist/configs/typechecked.js"
    },
    "./vitest": {
      "types": "./dist/configs/vitest.d.ts",
      "default": "./dist/configs/vitest.js"
    },
    "./jest": {
      "types": "./dist/configs/jest.d.ts",
      "default": "./dist/configs/jest.js"
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/satya164/oxlint-config-satya164.git"
  },
  "author": "Satyajit Sahoo <satyajit.happy@gmail.com> (https://github.com/satya164/)",
  "publishConfig": {
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "prepack": "tsc",
    "release": "release-it --only-version",
    "test": "oxlint __tests__/"
  },
  "peerDependencies": {
    "oxlint": "*"
  },
  "devDependencies": {
    "@evilmartians/lefthook": "^1.11.12",
    "@release-it/conventional-changelog": "^10.0.1",
    "@types/react": "^19.2.14",
    "oxlint": "^1.53.0",
    "oxlint-tsgolint": "^0.16.0",
    "release-it": "^19.0.2",
    "typescript": "^5.9.3"
  }
}
